<%- include('components/header', {name: "Detail Akun"}) %>
<main class="flex-grow-1 d-flex">
  <div class="container-fluid w-100 d-flex justify-content-center align-items-center">
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card">
        <div class="card-body p-4">
          <h2 class="text-center mb-4">Menyunting Detail Akun: <%= currentUser.username %></h2>
          
          <form class="row g-3" method="post" action="/user/updateDetails">
            <div class="mb-3 col-md-6">
              <label for="fullName" class="form-label">Nama Lengkap</label>
              <input type="text" class="form-control" id="fullName" name="fullName" value="<%= currentUser.UserDetail.fullName %>">
            </div>

            <div class="mb-3 col-md-6">
              <label for="birthDate" class="form-label">Tanggal Lahir</label>
              <input type="date" class="form-control" id="birthDate" name="birthDate" value="<%= currentUser.UserDetail.birthDate.toISOString().split('T')[0] %>">
            </div>
            
            <div class="mb-3 col-12">
              <label for="bio" class="form-label">Biodata</label>
              <textarea class="form-control" id="bio" name="bio"><%= currentUser.UserDetail.bio %></textarea>
            </div>

            <div class="col-auto d-block mx-auto">
              <button type="submit" class="btn btn-secondary">Terapkan Suntingan</button>
            </div>
          </form>        
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('components/footer') %>