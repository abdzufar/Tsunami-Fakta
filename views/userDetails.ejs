<%- include('components/header', {name: "Detail Akun"}) %>
<main class="flex-grow-1 d-flex">
  <div class="container-fluid w-100 d-flex justify-content-center align-items-center">
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card">
        <div class="card-body p-4">
          <h2 class="text-center mb-4">Detail Akun: <%= currentUser.username %></h2>
          
          <form class="row g-3">
            <div class="mb-3 col-md-6">
              <label for="fullName" class="form-label">Nama Lengkap</label>
              <input type="text" class="form-control" id="fullName" name="fullName" value="<%= currentUser.UserDetail.fullName %>" disabled>
            </div>

            <div class="mb-3 col-md-6">
              <label for="birthDate" class="form-label">Tanggal Lahir</label>
              <input type="text" class="form-control" id="birthDate" name="birthDate" value="<%= currentUser.UserDetail.formattedBirthDate %> (<%= currentUser.UserDetail.age %> tahun)" disabled>
            </div>
            
            <div class="mb-3 col-12">
              <label for="bio" class="form-label">Biodata</label>
              <textarea class="form-control" id="bio" name="bio" disabled><%= currentUser.UserDetail.bio %></textarea>
            </div>

            <div class="col-auto d-block mx-auto">
              <a href="/user/updateDetails" class="btn btn-outline-secondary">Sunting Detail Akun</a>
            </div>
          </form>        
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('components/footer') %>