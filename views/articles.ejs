<%- include('components/header', {name: "Landing Page"}) %>
<div class="text-center pt-5 pb-5 text-bg-info">
  <h1 class="display-5 fw-bold">TSUNAMI FAKTA</h1>
  <div class="col-lg-6 mx-auto">
    <p class="lead">Sumber informasi terpercaya yang ada di muka bumi.</p>
    <p class="blockquote-footer">Banyak Informasi seputar olahraga, teknologi, hiburan dan masih banyak lagi.</p>
  </div>
</div>
<div class="container mt-5">
  <% if (currentUser !== null && currentUser.role === "Penulis") { %>
    <a href="/article/add" class="btn btn-outline-success mb-5">Add new Article</a>
  <% } %>
  <a href="#" class="btn btn-outline-info mb-5">See bookmarked article</a>
  <div class="row g-4 mb-5">
    <% if (data.length === 0) { %>
     <h1 class="display-5 text-center">Article Data Empty</h1>
    <% } %>
    <% data.forEach(item => { %>
      <div class="col-lg-3">
        <div class="card">
          <img src="http://<%= item.thumbnailPicture %>" class="card-img-top" alt="<%= item.title %>">
          <div class="card-body">
            <h5 class="card-title"><%= item.title %></h5>
            <p class="card-text"><%= cutContent(item.content) %></p>
            <a href="/article/<%= item.id %>" class="btn btn-primary">See Details</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<%- include('components/footer') %>